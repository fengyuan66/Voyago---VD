{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://voyago-api-pzkm.onrender.com/api/:path*"
    },
    {
      "source": "/transiter-api/:path*",
      "destination": "https://transiter-api.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
